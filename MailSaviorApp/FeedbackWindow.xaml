<Window x:Class="MailSaviorApp.FeedbackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historique des Feedbacks" Height="400" Width="600">
    <Grid>
        <ListView Name="FeedbackListView" Margin="10">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Date" Width="150" DisplayMemberBinding="{Binding created_at}" />
                    <GridViewColumn Header="Prédiction" Width="90" DisplayMemberBinding="{Binding predicted_label}" />
                    <GridViewColumn Header="Score" Width="70" DisplayMemberBinding="{Binding suspicion_score}" />
                    <GridViewColumn Header="Retour" Width="80" DisplayMemberBinding="{Binding feedback_label}" />
                    <GridViewColumn Header="Correct" Width="70" DisplayMemberBinding="{Binding feedback_correct}" />
                    <GridViewColumn Header="Taille" Width="60" DisplayMemberBinding="{Binding text_length}" />
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
